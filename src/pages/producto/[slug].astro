---
import LayoutV2 from '../../layouts/LayoutV2.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PriceDisplay from '../../components/PriceDisplay.astro';
import SizeSelector from '../../components/SizeSelector.astro';
import FloatingWhatsApp from '../../components/FloatingWhatsApp.astro';
import catsData from '../../data/categorias.json';
import prodsData from '../../data/productos.json';

export async function getStaticPaths() {
  const prods = prodsData as any[];
  return prods.map((prod: any) => ({
    params: { slug: prod.slug },
    props: { producto: prod },
  }));
}

const { producto } = Astro.props as { producto: any };
const cats = catsData as any[];
const categoria = cats.find((c: any) => c.id === producto.categoriaId);
const precios = Object.values(producto.precios).filter((p): p is number => typeof p === 'number');
const minPrecio = Math.min(...precios);
const maxPrecio = Math.max(...precios);
const sizes = Object.keys(producto.precios) as string[];
const whatsappMsg = encodeURIComponent(`Hola! Quiero pedir ${producto.nombre}`);

const siteUrl = 'https://theneonsyndicate.com';
const productUrl = `${siteUrl}/producto/${producto.slug}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${productUrl}/#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Catálogo', item: `${siteUrl}/catalogo` },
    { '@type': 'ListItem', position: 3, name: producto.nombre, item: productUrl },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${productUrl}/#product`,
  name: producto.nombre,
  image: [ `${siteUrl}${producto.imagen}` ],
  description: producto.descripcion,
  sku: producto.slug,
  mpn: producto.slug,
  brand: { '@type': 'Brand', name: 'The Neon Syndicate' },
  category: categoria?.nombre || producto.categoriaId,
  offers: {
    '@type': 'Offer',
    url: productUrl,
    price: minPrecio,
    priceCurrency: 'EUR',
    priceValidUntil: '2027-12-31',
    availability: 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: {
        '@type': 'MonetaryAmount',
        value: 0,
        currency: 'EUR',
      },
      shippingDestination: {
        '@type': 'DefinedRegion',
        addressCountry: 'ES',
      },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: {
          '@type': 'QuantitativeValue',
          minValue: 1,
          maxValue: 3,
          unitCode: 'DAY',
        },
        transitTime: {
          '@type': 'QuantitativeValue',
          minValue: 2,
          maxValue: 5,
          unitCode: 'DAY',
        },
      },
    },
  },
};
---

<LayoutV2 title={`${producto.nombre} | The Neon Syndicate`} description={producto.descripcion} image={producto.imagen} jsonLd={[productSchema, breadcrumbSchema]}>
  <Header />
  <FloatingWhatsApp />

  <main class="pt-20 md:pt-24">
    <div class="container-v2">
      <Breadcrumb items={[
        { label: 'Catálogo', href: '/catalogo' },
        { label: producto.nombre, href: `/producto/${producto.slug}` },
      ]} />
    </div>

    <section class="pb-16 md:pb-20">
      <div class="container-v2">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16">
          <!-- Image -->
          <div class="reveal">
            <div class="relative aspect-square overflow-hidden bg-[var(--color-bg-elevated)] rounded-3xl border-2 border-gray-100">
              <img
                src={producto.imagen}
                alt={producto.nombre}
                width="800"
                height="800"
                class="w-full h-full object-cover image-fade-in"
                onload="this.classList.add('loaded')"
              />
            </div>
          </div>

          <!-- Info -->
          <div class="flex flex-col reveal" style="transition-delay: 100ms">
            <span class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent-pink)] font-body">
              {categoria?.nombre || producto.categoriaId}
            </span>

            <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold text-[var(--color-text-primary)] mt-3 leading-tight">
              {producto.nombre}
            </h1>

            <PriceDisplay minPrice={minPrecio} maxPrice={maxPrecio} productName={producto.nombre} />

            <p class="font-body text-[var(--color-text-secondary)] mt-6 leading-relaxed">
              {producto.descripcion}
            </p>

            <SizeSelector sizes={sizes} prices={producto.precios} productName={producto.nombre} />

            <!-- CTA -->
            <div class="mt-8 space-y-3">
              <a
                id="whatsapp-btn"
                href={`https://wa.me/34722617372?text=${whatsappMsg}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary w-full justify-center text-base gap-2 py-4"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Pedir por WhatsApp
              </a>
              <p class="text-xs text-[var(--color-text-muted)] text-center font-body font-medium">
                ✅ Envío gratis a España · Pago por Bizum
              </p>
            </div>

            <!-- Info boxes -->
            <div class="mt-10 pt-8 border-t border-gray-100 grid grid-cols-1 sm:grid-cols-3 gap-4">
              {[
                { icon: '✦', title: 'Material', desc: 'Vinilo premium con retroiluminación LED', color: 'text-[var(--color-accent-pink)]' },
                { icon: '✦', title: 'Plug & Play', desc: 'Listo para colgar. Incluye transformador USB', color: 'text-[var(--color-accent-blue)]' },
                { icon: '✦', title: 'Personalización', desc: '¿Quieres tu diseño? Contáctanos', color: 'text-[var(--color-accent-purple)]' },
              ].map((info) => (
                <div class="p-4 rounded-2xl bg-[var(--color-bg-elevated)]/50 space-y-2">
                  <span class={`text-lg font-bold ${info.color}`}>{info.icon}</span>
                  <h4 class="font-body text-sm font-bold text-[var(--color-text-primary)]">{info.title}</h4>
                  <p class="text-xs text-[var(--color-text-muted)]">{info.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</LayoutV2>
