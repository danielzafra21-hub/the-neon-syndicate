---
import LayoutV2 from '../layouts/LayoutV2.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
---

<LayoutV2 title="Contacto | The Neon Syndicate" description="Contacta con The Neon Syndicate por WhatsApp o email. Aceptamos Bizum. Envío gratis a España.">
  <Header />
  <FloatingWhatsApp />

  <main class="pt-24 md:pt-28">
    <section class="section-v2">
      <div class="container-v2">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-12 reveal">
            <h1 class="font-heading text-4xl md:text-6xl font-extrabold">
              <span class="gradient-text">HABLEMOS</span>
            </h1>
            <p class="font-body text-[var(--color-text-secondary)] mt-4 text-lg leading-relaxed">
              Estamos aquí para ayudarte. Contáctanos directamente por WhatsApp.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal" style="transition-delay: 100ms">
            <!-- WhatsApp -->
            <div class="bg-white rounded-3xl p-8 md:p-10 border-2 border-gray-100 space-y-5 hover:shadow-xl hover:border-[var(--color-accent-pink)] transition-all duration-300">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-accent-pink)] to-[var(--color-accent-purple)] flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <h2 class="font-heading text-xl font-extrabold text-[var(--color-text-primary)]">WhatsApp</h2>
              <p class="font-body text-sm text-[var(--color-text-secondary)] leading-relaxed">Respuesta rápida. Estamos disponibles en horario laboral.</p>
              <div class="pt-2">
                <a href="https://wa.me/34722617372" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[var(--color-accent-pink)] hover:text-[var(--color-accent-purple)] transition-colors font-body font-bold whitespace-nowrap">
                  +34 722 61 73 72 <span class="text-lg">→</span>
                </a>
              </div>
            </div>

            <!-- Bizum -->
            <div class="bg-white rounded-3xl p-8 md:p-10 border-2 border-gray-100 space-y-5 hover:shadow-xl hover:border-[var(--color-accent-blue)] transition-all duration-300">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-accent-blue)] to-[var(--color-accent-purple)] flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h2 class="font-heading text-xl font-extrabold text-[var(--color-text-primary)]">Bizum</h2>
              <p class="font-body text-sm text-[var(--color-text-secondary)] leading-relaxed">Aceptamos pago por Bizum. Contacta por WhatsApp para más información.</p>
              <p class="font-body text-xs text-[var(--color-text-muted)] pt-1">Elige → Contacta → Confirma → Recibe</p>
            </div>
          </div>

          <!-- Steps -->
          <div class="mt-16 reveal">
            <h2 class="font-heading text-2xl md:text-3xl font-extrabold text-center mb-10">
              Cómo <span class="gradient-text">Comprar</span>
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
              {[
                { paso: '01', color: 'from-[var(--color-accent-pink)] to-[var(--color-accent-purple)]', titulo: 'Elige', desc: 'Tu producto y tamaño del catálogo' },
                { paso: '02', color: 'from-[var(--color-accent-purple)] to-[var(--color-accent-blue)]', titulo: 'Contacta', desc: 'Por WhatsApp con tu pedido' },
                { paso: '03', color: 'from-[var(--color-accent-blue)] to-[var(--color-accent-green)]', titulo: 'Confirma', desc: 'Disponibilidad y precio final' },
                { paso: '04', color: 'from-[var(--color-accent-yellow)] to-[var(--color-accent-orange)]', titulo: 'Recibe', desc: 'Pago Bizum y envío gratis' },
              ].map((step) => (
                <div class="text-center space-y-3 p-6 rounded-2xl bg-white border-2 border-gray-100 hover:shadow-lg transition-shadow">
                  <span class={`inline-block text-4xl font-extrabold bg-gradient-to-br ${step.color} bg-clip-text text-transparent`}>{step.paso}</span>
                  <h3 class="font-heading text-lg font-extrabold text-[var(--color-text-primary)]">{step.titulo}</h3>
                  <p class="font-body text-sm text-[var(--color-text-secondary)]">{step.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</LayoutV2>
