---
import LayoutV2 from '../layouts/LayoutV2.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
---

<LayoutV2 title="Sobre Nosotros | The Neon Syndicate — Wall Art de Neón LED" description="Conoce la historia de The Neon Syndicate. Wall art de neón LED personalizado con diseño único, fabricación artesanal y envío gratis a España.">
  <Header />
  <FloatingWhatsApp />

  <main class="pt-20 md:pt-24">
    <!-- Hero Section -->
    <section class="relative py-20 md:py-28 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent-pink)] via-[var(--color-accent-purple)] to-[var(--color-accent-blue)]" />
      <div class="absolute inset-0 bg-black/10" />
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-[15%] left-[10%] w-72 h-72 rounded-full bg-white/5 blur-3xl pulse-glow" />
        <div class="absolute bottom-[20%] right-[15%] w-96 h-96 rounded-full bg-white/5 blur-3xl pulse-glow" style="animation-delay: 1s" />
      </div>

      <div class="container-v2 relative z-10">
        <div class="max-w-3xl mx-auto text-center reveal">
          <span class="inline-block font-body text-xs font-semibold uppercase tracking-[0.25em] text-white/60 mb-4">Nuestra Historia</span>
          <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight">
            DONDE LA LUZ <br/><span class="text-[var(--color-accent-yellow)]">ENCUENTRA SU FORMA</span>
          </h1>
          <p class="font-body text-lg md:text-xl text-white/70 mt-6 max-w-2xl mx-auto leading-relaxed">
            En The Neon Syndicate transformamos ideas en obras de luz. Cada pieza es única, 
            creada a mano con vinilo LED premium para quienes buscan algo más que decoración.
          </p>
        </div>
      </div>
    </section>

    <!-- Brand Story -->
    <section class="section-v2">
      <div class="container-v2">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-center">
          <div class="reveal">
            <div class="aspect-square rounded-3xl overflow-hidden bg-[var(--color-bg-elevated)] border-2 border-gray-100">
              <img
                src="/images/productos/logo-theneonsyndicate.png"
                alt="The Neon Syndicate Logo"
                width="600"
                height="600"
                class="w-full h-full object-contain p-8 md:p-12 image-fade-in"
                onload="this.classList.add('loaded')"
              />
            </div>
          </div>
          <div class="reveal" style="transition-delay: 100ms">
            <span class="font-body text-xs font-bold uppercase tracking-widest text-[var(--color-accent-pink)]">Desde 2024</span>
            <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-[var(--color-text-primary)] mt-3 leading-tight">
              Nacimos para <span class="gradient-text">iluminar</span> tus espacios
            </h2>
            <p class="font-body text-[var(--color-text-secondary)] mt-6 leading-relaxed">
              The Neon Syndicate nace de una pasión: convertir paredes en lienzos de luz. 
              Lo que empezó como un taller artesanal de vinilo LED se ha convertido en una 
              referencia para coleccionistas, militares, gamers y amantes del diseño que buscan 
              piezas exclusivas que realmente brillan.
            </p>
            <p class="font-body text-[var(--color-text-secondary)] mt-4 leading-relaxed">
              Cada cuadro de neón LED que sale de nuestro taller está hecho a medida, 
              con materiales premium, iluminación LED de bajo consumo y un nivel de detalle 
              que marca la diferencia. No hacemos decoración. Creamos declaraciones de intenciones.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="section-v2 bg-[var(--color-bg-elevated)]/50">
      <div class="container-v2">
        <div class="text-center max-w-2xl mx-auto mb-14 reveal">
          <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-[var(--color-text-primary)]">
            Nuestros <span class="gradient-text">Valores</span>
          </h2>
          <p class="font-body text-[var(--color-text-secondary)] mt-3 leading-relaxed">
            Lo que nos define como taller y como marca.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
          <div class="bg-white rounded-2xl p-8 border-2 border-gray-100 hover:shadow-xl hover:border-[var(--color-accent-pink)] transition-all duration-300 reveal">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[var(--color-accent-pink)] to-[var(--color-accent-purple)] flex items-center justify-center mb-5 shrink-0">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>
            </div>
            <h3 class="font-heading text-xl font-extrabold text-[var(--color-text-primary)] mb-3">Artesanía LED</h3>
            <p class="font-body text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Cada pieza se fabrica a mano en nuestro taller. Cortamos, doblamos y soldamos el neón 
              flex con precisión quirúrgica. No producimos en masa: creamos.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 border-2 border-gray-100 hover:shadow-xl hover:border-[var(--color-accent-blue)] transition-all duration-300 reveal" style="transition-delay: 100ms">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[var(--color-accent-blue)] to-[var(--color-accent-cyan)] flex items-center justify-center mb-5 shrink-0">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" /></svg>
            </div>
            <h3 class="font-heading text-xl font-extrabold text-[var(--color-text-primary)] mb-3">Diseño Exclusivo</h3>
            <p class="font-body text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Desde heráldica militar hasta cultura pop. Colaboramos con clientes para crear 
              piezas que no existen en ningún otro sitio. Tu idea, nuestra luz.
            </p>
          </div>

          <div class="bg-white rounded-2xl p-8 border-2 border-gray-100 hover:shadow-xl hover:border-[var(--color-accent-purple)] transition-all duration-300 reveal" style="transition-delay: 200ms">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-[var(--color-accent-purple)] to-[var(--color-accent-pink)] flex items-center justify-center mb-5 shrink-0">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
            </div>
            <h3 class="font-heading text-xl font-extrabold text-[var(--color-text-primary)] mb-3">Compromiso Total</h3>
            <p class="font-body text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Envío gratis a España, pago por Bizum y atención personalizada por WhatsApp. 
              De nuestro taller a tu pared, sin intermediarios.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="section-v2">
      <div class="container-v2">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
          <div class="text-center reveal p-6 rounded-2xl bg-white border-2 border-gray-100">
            <p class="font-heading text-3xl md:text-4xl font-extrabold gradient-text">24+</p>
            <p class="font-body text-sm text-[var(--color-text-secondary)] mt-2">Diseños Exclusivos</p>
          </div>
          <div class="text-center reveal p-6 rounded-2xl bg-white border-2 border-gray-100" style="transition-delay: 100ms">
            <p class="font-heading text-3xl md:text-4xl font-extrabold gradient-text">3</p>
            <p class="font-body text-sm text-[var(--color-text-secondary)] mt-2">Categorías</p>
          </div>
          <div class="text-center reveal p-6 rounded-2xl bg-white border-2 border-gray-100" style="transition-delay: 200ms">
            <p class="font-heading text-3xl md:text-4xl font-extrabold gradient-text">100%</p>
            <p class="font-body text-sm text-[var(--color-text-secondary)] mt-2">Hecho a Mano</p>
          </div>
          <div class="text-center reveal p-6 rounded-2xl bg-white border-2 border-gray-100" style="transition-delay: 300ms">
            <p class="font-heading text-3xl md:text-4xl font-extrabold gradient-text">0€</p>
            <p class="font-body text-sm text-[var(--color-text-secondary)] mt-2">Envío Gratis</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Media -->
    <section class="section-v2">
      <div class="container-v2">
        <div class="max-w-3xl mx-auto text-center reveal">
          <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-[var(--color-text-primary)]">
            Síguenos en <span class="gradient-text">Redes</span>
          </h2>
          <p class="font-body text-[var(--color-text-secondary)] mt-3 leading-relaxed max-w-md mx-auto">
            Compartimos procesos, diseños exclusivos y el día a día del taller.
          </p>
          <div class="flex items-center justify-center gap-4 mt-8">
            <a href="https://www.instagram.com/theneonsyndicate_official/" target="_blank" rel="noopener noreferrer" class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-accent-pink)] to-[var(--color-accent-purple)] flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-[var(--color-glow-pink)] transition-all duration-300 group" aria-label="Instagram">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="https://www.tiktok.com/@theneonsyndicateofficial?_r=1&_t=ZN-93arUbL4ouk" target="_blank" rel="noopener noreferrer" class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-accent-blue)] to-[var(--color-accent-cyan)] flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-[var(--color-glow-blue)] transition-all duration-300 group" aria-label="TikTok">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
            <a href="https://wa.me/34722617372" target="_blank" rel="noopener noreferrer" class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-accent-green)] to-[var(--color-accent-green)] flex items-center justify-center hover:scale-110 hover:shadow-xl hover:shadow-[var(--color-glow-green)] transition-all duration-300 group" aria-label="WhatsApp">
              <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="section-v2 bg-[var(--color-bg-elevated)]/50">
      <div class="container-v2">
        <div class="text-center max-w-2xl mx-auto mb-14 reveal">
          <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-[var(--color-text-primary)]">
            Cómo <span class="gradient-text">Creamos</span>
          </h2>
          <p class="font-body text-[var(--color-text-secondary)] mt-3 leading-relaxed">
            De la idea a tu pared. Así es nuestro proceso artesanal.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          <div class="text-center p-6 rounded-2xl bg-white border-2 border-gray-100 hover:shadow-lg transition-shadow reveal">
            <span class="inline-block text-4xl font-extrabold bg-gradient-to-br from-[var(--color-accent-pink)] to-[var(--color-accent-purple)] bg-clip-text text-transparent mb-3">01</span>
            <h3 class="font-heading text-lg font-extrabold text-[var(--color-text-primary)] mb-2">Diseño</h3>
            <p class="font-body text-sm text-[var(--color-text-secondary)]">Creamos el arte digital con tu diseño o uno de nuestros exclusivos</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-white border-2 border-gray-100 hover:shadow-lg transition-shadow reveal" style="transition-delay: 100ms">
            <span class="inline-block text-4xl font-extrabold bg-gradient-to-br from-[var(--color-accent-purple)] to-[var(--color-accent-blue)] bg-clip-text text-transparent mb-3">02</span>
            <h3 class="font-heading text-lg font-extrabold text-[var(--color-text-primary)] mb-2">Fabricación</h3>
            <p class="font-body text-sm text-[var(--color-text-secondary)]">Montamos el neón flex LED a medida sobre vinilo premium</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-white border-2 border-gray-100 hover:shadow-lg transition-shadow reveal" style="transition-delay: 200ms">
            <span class="inline-block text-4xl font-extrabold bg-gradient-to-br from-[var(--color-accent-blue)] to-[var(--color-accent-green)] bg-clip-text text-transparent mb-3">03</span>
            <h3 class="font-heading text-lg font-extrabold text-[var(--color-text-primary)] mb-2">Control</h3>
            <p class="font-body text-sm text-[var(--color-text-secondary)]">Probamos cada pieza antes de empaquetarla con protección</p>
          </div>
          <div class="text-center p-6 rounded-2xl bg-white border-2 border-gray-100 hover:shadow-lg transition-shadow reveal" style="transition-delay: 300ms">
            <span class="inline-block text-4xl font-extrabold bg-gradient-to-br from-[var(--color-accent-yellow)] to-[var(--color-accent-orange)] bg-clip-text text-transparent mb-3">04</span>
            <h3 class="font-heading text-lg font-extrabold text-[var(--color-text-primary)] mb-2">Envío</h3>
            <p class="font-body text-sm text-[var(--color-text-secondary)]">Recibes tu pedido en casa. Plug & Play. Sin complicaciones.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-v2">
      <div class="container-v2">
        <div class="relative overflow-hidden rounded-3xl py-16 md:py-20 px-6 md:px-16">
          <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-accent-pink)] via-[var(--color-accent-purple)] to-[var(--color-accent-blue)]" />
          <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSI+PGNpcmNsZSBjeD0iMzAiIGN5PSIzMCIgcj0iMiIvPjwvZz48L2c+PC9zdmc+')] opacity-50" />

          <div class="relative z-10 text-center">
            <h2 class="font-heading text-3xl md:text-4xl font-extrabold text-white">
              ¿Listo para <span class="text-[var(--color-accent-yellow)]">brillar</span>?
            </h2>
            <p class="font-body text-lg text-white/80 mt-3 max-w-lg mx-auto">
              Háblanos por WhatsApp y creamos tu pieza única.
