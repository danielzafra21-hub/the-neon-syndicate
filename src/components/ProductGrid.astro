---
import ProductCard from './ProductCard.astro';

export interface Props {
  products: any[];
  categories: any[];
}

const { products, categories } = Astro.props;
---

{products.length > 0 ? (
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
    {products.map((prod: any) => {
      const cat = categories.find((c: any) => c.id === prod.categoriaId);
      return <ProductCard product={prod} category={cat} />;
    })}
  </div>
) : (
  <div class="text-center py-20">
    <p class="font-body text-[var(--color-text-muted)]">No hay productos en esta categoría.</p>
    <a href="/catalogo" class="inline-block mt-4 text-sm font-bold text-[var(--color-accent-pink)] hover:text-[var(--color-accent-purple)] font-body uppercase tracking-wider transition-colors">
      Ver catálogo completo →
    </a>
  </div>
)}
