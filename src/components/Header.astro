---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/categoria/militar-art', label: 'Militar Art' },
  { href: '/categoria/icon-art', label: 'Icon Art' },
  { href: '/categoria/set-ups', label: 'Set Ups' },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/about', label: 'Sobre Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-xl border-b border-gray-100">
  <div class="container-v2 flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex items-center gap-3 group">
      <img
        src="/images/productos/logo-theneonsyndicate.png"
        alt="The Neon Syndicate"
        width="32"
        height="32"
        class="w-8 h-8 rounded-full object-cover"
      />
      <span class="font-heading text-lg md:text-xl font-extrabold tracking-tight text-[var(--color-text-primary)]">
        THE <span class="text-[var(--color-accent-pink)]">NEON</span> SYNDICATE
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-6 lg:gap-8">
      {navLinks.map((link) => {
        const isActive = Astro.url.pathname === link.href || (link.href !== '/' && Astro.url.pathname.startsWith(link.href));
        return (
        <a
          href={link.href}
          class:list={[
            'relative text-sm font-body font-semibold tracking-wide uppercase transition-colors duration-200',
            isActive ? 'text-[var(--color-accent-pink)]' : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-pink)]',
          ]}
          aria-current={isActive ? 'page' : undefined}
        >
          {link.label}
          {isActive && <span class="absolute -bottom-1 left-0 right-0 h-0.5 bg-[var(--color-accent-pink)]" />}
        </a>
        );
      })}
    </nav>

    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2 group" aria-label="Abrir menú">
      <span class="block w-6 h-[3px] bg-[var(--color-text-primary)] rounded-full transition-transform duration-300 group-hover:bg-[var(--color-accent-pink)]" />
      <span class="block w-6 h-[3px] bg-[var(--color-text-primary)] rounded-full transition-opacity duration-300 group-hover:bg-[var(--color-accent-pink)]" />
      <span class="block w-6 h-[3px] bg-[var(--color-text-primary)] rounded-full transition-transform duration-300 group-hover:bg-[var(--color-accent-pink)]" />
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden fixed inset-0 z-40 bg-white">
    <div class="container-v2 flex flex-col items-center justify-center h-full gap-8">
      <button id="menu-close" class="absolute top-5 right-5 text-[var(--color-text-primary)] text-3xl hover:text-[var(--color-accent-pink)] transition-colors" aria-label="Cerrar menú">
        ✕
      </button>
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-heading text-3xl font-extrabold text-[var(--color-text-primary)] hover:text-[var(--color-accent-pink)] transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('menu-close');
    const links = menu?.querySelectorAll('a');

    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    }
    if (close && menu) {
      close.addEventListener('click', () => {
        menu.classList.add('hidden');
        document.body.style.overflow = '';
      });
    }
    links?.forEach((link) => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
        document.body.style.overflow = '';
      });
    });
  });
</script>
