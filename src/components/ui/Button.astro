---
export interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
}

const { href, variant = 'primary', size = 'md' } = Astro.props;

const baseClass = 'inline-flex items-center justify-center font-body font-bold text-sm uppercase tracking-wider transition-all duration-300 focus:outline-none';

const variantClass: Record<string, string> = {
  primary: 'rounded-full bg-[var(--color-accent-pink)] text-white hover:scale-105 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-[var(--color-glow-pink)]',
  secondary: 'rounded-full bg-[#0f0f1a] text-white hover:bg-[#1a1a2e] hover:scale-105',
  outline: 'rounded-full border-2 border-[var(--color-accent-pink)] text-[var(--color-accent-pink)] hover:bg-[var(--color-accent-pink)] hover:text-white',
  ghost: 'rounded-full border-2 border-white/30 text-white hover:bg-white/10 hover:border-white',
};

const sizeClass: Record<string, string> = {
  sm: 'px-5 py-2 text-xs',
  md: 'px-8 py-3.5',
  lg: 'px-10 py-4 text-base',
};
---

<a href={href} class={`${baseClass} ${variantClass[variant] || variantClass.primary} ${sizeClass[size] || sizeClass.md}`}>
  <slot />
</a>
